# Variabel Lingkungan — Hermes Agent
# Template ini HANYA untuk referensi.
# Masukkan nilai asli ke Google Apps Script > Project Settings > Script Properties

# ─── Telegram Bot ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=12345678:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_SECRET_TOKEN=buat_random_string_minimal_20_karakter_aman

# ─── OpenRouter (LLM Gateway) ─────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=google/gemini-flash-1.5
# Model alternatif:
# - anthropic/claude-3-haiku
# - openai/gpt-4o-mini
# - meta-llama/llama-3.1-8b-instruct:free

# ─── News API ────────────────────────────────────────────────────
NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Calendar ─────────────────────────────────────────────
# Gunakan 'primary' untuk kalender utama,
# atau email spesifik seperti: nama@gmail.com
CALENDAR_ID=primary

# ─── Debug ───────────────────────────────────────────────────────
DEBUG_MODE=false
